{
    "name": "luxfiro-launcher",
    "productName": "Luxfiro Launcher",
    "version": "1.0.3",
    "description": "Launcher Oficial de Luxfiro Studio",
    "main": "src/app.js",
    "author": {
        "name": "ImNotRuso/Mqrttin",
        "email": "contacto.imnortuso@gmail.com",
        "url": "https://github.com/Mqrttin"
    },
    "url": "http://free1.empatichost.com:25572/luxfirolauncher",
    "scripts": {
        "start": "cross-env-shell NODE_ENV=dev electron .",
        "dev": "cross-env-shell DEV_TOOL=open nodemon --exec npm start",
        "build": "node build.js --obf=true --build=platform",
        "icon": "node build.js --icon=https://raw.githubusercontent.com/luuxis/Selvania-Launcher/master/src/assets/images/icon.png"
    },
    "license": "CCANC",
    "nodemonConfig": {
        "ext": "js,html,css",
        "ignore": "**/test"
    },
    "build": {
        "appId": "com.luxfiro.launcher",
        "productName": "Luxfiro Launcher",
        "win": {
            "requestedExecutionLevel": "asInvoker"
        }
    },
    "dependencies": {
        "azuriom-auth": "^1.0.1",
        "discord-rich-presence": "^0.0.8",
        "electron-updater": "^6.1.8",
        "extract-zip": "^2.0.1",
        "minecraft-java-core": "^4.2.3",
        "minecraft-server-util": "^5.4.4",
        "node-bdd": "^2.0.4",
        "node-fetch": "^2.7.0",
        "three": "^0.183.1",
        "xml-js": "^1.6.11"
    },
    "devDependencies": {
        "cross-env": "^7.0.3",
        "electron": "^30.0.9",
        "electron-builder": "^24.13.3",
        "javascript-obfuscator": "^4.1.0",
        "jimp": "^0.22.12",
        "nodemon": "^3.1.2",
        "png2icons": "^2.0.1"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Mqrttin/LuxfiroLauncher.git"
    }
}
